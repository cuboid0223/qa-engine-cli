# Copy this file to .env and fill in values.
# .env is gitignored — never commit real credentials.

# Base URL for CI runs (overrides playwright.config.ts default)
TARGET_URL=http://localhost:3000

# ── Role credentials for permission_matrix skill ──────────────────────────────
# Add one EMAIL + PASSWORD pair per role.
# Naming convention: ROLE_<ROLENAME>_EMAIL / ROLE_<ROLENAME>_PASSWORD
# ROLENAME must be uppercase and match what the skill reads (e.g. ADMIN, EDITOR, VIEWER).

ROLE_ADMIN_EMAIL=admin@example.com
ROLE_ADMIN_PASSWORD=

ROLE_EDITOR_EMAIL=editor@example.com
ROLE_EDITOR_PASSWORD=

ROLE_VIEWER_EMAIL=viewer@example.com
ROLE_VIEWER_PASSWORD=

# Add more roles as needed:
# ROLE_MANAGER_EMAIL=
# ROLE_MANAGER_PASSWORD=
